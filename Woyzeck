  #chatContainer { flex: 1; display: flex; flex-direction: column; }
  .chat-box { flex: 1; min-height: 300px; max-height: 460px; overflow-y: auto; padding: 1.1rem; display: flex; flex-direction: column; gap: 14px; scroll-behavior: smooth; }
  .chat-box::-webkit-scrollbar { width: 3px; }
  .chat-box::-webkit-scrollbar-thumb { background: #2e2416; border-radius: 2px; }
  .chat-placeholder { text-align: center; font-style: italic; font-size: 0.85rem; color: #3a3020; padding: 3rem 2rem; line-height: 1.9; }
  .msg { display: flex; gap: 9px; align-items: flex-start; }
  .msg.user { flex-direction: row-reverse; }
  .msg-avatar { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: bold; flex-shrink: 0; }
  .msg-body { display: flex; flex-direction: column; max-width: 80%; }
  .msg-sender { font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase; color: #5a5040; margin-bottom: 3px; }
  .msg.user .msg-sender { text-align: right; }
  .msg-bubble { padding: 9px 13px; font-size: 0.87rem; line-height: 1.75; border-radius: 4px; border: 1px solid #2e2416; }
