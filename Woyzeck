<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Georgia', serif; background: #0d0a06; color: #e2d5b8; min-height: 100vh; display: flex; flex-direction: column; align-items: center; }
