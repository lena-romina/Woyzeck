  .content { width: 100%; max-width: 680px; flex: 1; display: flex; flex-direction: column; }
  .q-panel { padding: 1rem; display: none; flex-direction: column; gap: 0.5rem; }
  .q-panel.visible { display: flex; }
  .q-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .q-chip { font-family: 'Georgia', serif; font-size: 0.82rem; font-style: italic; padding: 6px 14px; border-radius: 50px; border: 1px solid #2e2416; background: #1a1208; color: #b8a880; cursor: pointer; transition: all 0.15s; }
  .q-chip:hover { border-color: #c9a84c77; color: #c9a84c; background: #1e1810; }
  .chat-panel { display: none; flex-direction: column; flex: 1; }
